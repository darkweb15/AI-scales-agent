# ============================================
# SalesAI — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Database (get free from neon.tech)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# Redis (local or get free from upstash.com)
REDIS_URL=redis://localhost:6379/0

# Security
HMAC_SECRET=your-random-secret-key-here

# OpenAI (platform.openai.com — $5 free credit)
OPENAI_API_KEY=sk-...

# Telephony — Multiple providers (choose one)

# Vapi.ai — Best human voice AI (vapi.ai — $0.05/min)
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=  # optional — auto-fetched if empty

# Bland AI — Ultra-realistic Indian voice (bland.ai — $0.09/min)
BLAND_AI_API_KEY=

# ElevenLabs — Ultra-realistic voice synthesis (elevenlabs.io — $1 free credit)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Rachel (professional female)

# Twilio — Call delivery (console.twilio.com — $15 trial credit)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1...

# SignalWire — Alternative to Twilio (signalwire.com — free trial)
SIGNALWIRE_PROJECT_ID=
SIGNALWIRE_TOKEN=
SIGNALWIRE_SPACE_URL=
SIGNALWIRE_FROM_NUMBER=+1...
SIGNALWIRE_SIGNING_KEY=

# Public server URL for webhooks (use ngrok for local dev)
SERVER_URL=http://localhost:8001

# SendGrid — Emails (sendgrid.com — 100/day free)
SENDGRID_API_KEY=SG...
FROM_EMAIL=you@yourdomain.com

# Google Calendar (console.cloud.google.com — free)
GOOGLE_CALENDAR_CREDENTIALS_JSON={"type":"service_account",...}
GOOGLE_CALENDAR_ID=primary

# Orchestrator settings
ORCHESTRATOR_POLL_INTERVAL_SECONDS=30
COOLDOWN_MINUTES=60
MAX_COLD_CALL_ATTEMPTS=3
MAX_TOTAL_FOLLOW_UP_ATTEMPTS=5
MAX_TASK_RETRIES=3
FOLLOW_UP_DELAY_HOURS=24
SCHEDULING_WINDOW_DAYS=14
MAX_SLOTS_TO_OFFER=3
DEMO_DURATION_MINUTES=30
AUTO_REPLY_CONFIDENCE_THRESHOLD=0.75
CALLING_HOURS_START=9
CALLING_HOURS_END=17

# Optional: Slack alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
